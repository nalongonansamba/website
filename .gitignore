# dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# IDEs
/.idea/*
!/.idea/runConfigurations
.vscode/

# testing and coverage
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js and build outputs
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel

# Environment Files
# Removed .env and .env.* from here so they are tracked by git
# We only keep .local files ignored as they usually contain secrets
.env*.local

# Media Handling
/media
# Explicitly allow everything in public/media even if other media rules exist
!/public/media/